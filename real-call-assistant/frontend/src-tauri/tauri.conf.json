{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus AI",
  "version": "0.1.0",
  "identifier": "com.nexusai.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nexus AI",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "shadow": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/models/**/*"
    ],
    "externalBin": [
      "bin/nexus-ai-backend"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
